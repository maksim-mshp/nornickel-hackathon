[Unit]
Description=kmap R&D Knowledge Map
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/kmap/deploy/vm
ExecStart=/usr/bin/docker compose -f compose.prod.yml up -d --wait
ExecStop=/usr/bin/docker compose -f compose.prod.yml down
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
