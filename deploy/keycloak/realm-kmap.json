{
  "realm": "kmap",
  "enabled": true,
  "sslRequired": "none",
  "loginTheme": "keycloak",
  "accessTokenLifespan": 1800,
  "roles": {
    "realm": [
      {
        "name": "researcher",
        "description": "Исследователь"
      },
      {
        "name": "analyst",
        "description": "Аналитик"
      },
      {
        "name": "manager",
        "description": "Руководитель R&D"
      },
      {
        "name": "expert",
        "description": "Эксперт-валидатор"
      },
      {
        "name": "admin",
        "description": "Администратор"
      },
      {
        "name": "partner",
        "description": "Внешний партнёр"
      }
    ]
  },
  "clients": [
    {
      "clientId": "kmap-gateway",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false
    },
    {
      "clientId": "kmap-ui",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "protocolMappers": [
        {
          "name": "kmap-gateway-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "kmap-gateway",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "researcher",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Исследователь",
      "credentials": [
        {
          "type": "password",
          "value": "researcher",
          "temporary": false
        }
      ],
      "realmRoles": [
        "researcher"
      ],
      "requiredActions": [],
      "lastName": "(demo)",
      "email": "researcher@kmap.local"
